{
  "name": "ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "start": "electron dist-electron/main.js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@vitejs/plugin-vue": "6.0.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "41.5.0",
    "lucide-vue-next": "^0.561.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "4.2.4",
    "vue": "3.5.33"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@vue/test-utils": "2.4.10",
    "electron-builder": "26.8.1",
    "happy-dom": "^20.0.11",
    "typescript": "^5.9.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue-tsc": "^3.1.8"
  },
  "build": {
    "appId": "io.gocanto.macos.ui",
    "productName": "Mac OS Manager",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
